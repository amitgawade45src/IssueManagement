{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} | {Level:u3} | TraceId: {TraceId} | {Message:lj} | Ex: {Exception} | Source: {SourceContext} | Assembly: {AssemblyName} | {EnvironmentUserName} B{NewLine}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} | {Level:u3} | TraceId: {TraceId} | {Message:lj} | Ex: {Exception} | Source: {SourceContext}{NewLine}"
        }
      }
    ]
  }
}
