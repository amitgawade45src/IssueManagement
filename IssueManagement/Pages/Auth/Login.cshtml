@page
@model IssueManagement.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In ? BIM Issue Manager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        html, body { height: 100%; }
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        }
        .login-card {
            width: 100%;
            max-width: 400px;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        .login-header {
            background: #343a40;
            color: #fff;
            border-radius: 12px 12px 0 0;
            padding: 24px;
            text-align: center;
        }
        .login-header i { font-size: 2rem; }
        .login-body { padding: 32px 24px 24px; }
        .mock-badge {
            font-size: 0.7rem;
            letter-spacing: 0.05em;
        }
    </style>
</head>
<body>
    <div class="card login-card">
        <div class="login-header">
            <i class="bi bi-building"></i>
            <h4 class="mt-2 mb-1">BIM Issue Manager</h4>
            <span class="badge bg-warning text-dark mock-badge">MOCK LOGIN ? DEV ONLY</span>
        </div>
        <div class="login-body">
            <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
                <div class="mb-3">
                    <label class="form-label" for="DisplayName">Display Name</label>
                    <input type="text" id="DisplayName" asp-for="DisplayName" class="form-control"
                           placeholder="e.g. Mr. Sato" value="Mr. Sato" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="Email">Email</label>
                    <input type="email" id="Email" asp-for="Email" class="form-control"
                           placeholder="e.g. sato@@issuemanagement.local" value="sato@@issuemanagement.local" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="Role">Role</label>
                    <select id="Role" asp-for="Role" class="form-select">
                        <option value="Admin">Admin</option>
                        <option value="Manager">Manager</option>
                        <option value="Viewer">Viewer</option>
                    </select>
                    <div class="form-text text-muted">
                        <strong>Admin</strong> ? full access &middot;
                        <strong>Manager</strong> ? create, edit, upload &middot;
                        <strong>Viewer</strong> ? read-only
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </button>
            </form>
        </div>
    </div>
</body>
</html>
